@@ -0,0 +1,75 @@
+#!/usr/bin/env python3
+import json
+import os
+from pathlib import Path
+from urllib import request, error
+
+
+ROOT = Path(__file__).resolve().parent
+FUNCTIONS = [
+    {
+        "id": "lge_builder_action",
+        "name": "LGE Builder Draft Action",
+        "path": ROOT / "lge_builder_action.py",
+        "description": "Queues clonellm LGE builder drafts and returns preview/compare links.",
+        "global": True,
+    },
+    {
+        "id": "cns_mockup_builder_filter",
+        "name": "CNS Atlas Mockup Builder",
+        "path": ROOT / "cns_mockup_builder_filter.py",
+        "description": "Turns chat input into a schema-guided mockup-builder intake flow.",
+        "global": True,
+    },
+]
+OPENWEBUI_BASE_URL = os.environ.get("OPENWEBUI_BASE_URL", "http://localhost:8080").rstrip("/")
+OPENWEBUI_ADMIN_TOKEN = os.environ.get("OPENWEBUI_ADMIN_TOKEN", "")
+
+
+def http_json(method: str, url: str, payload: dict | None = None):
+    data = json.dumps(payload).encode("utf-8") if payload is not None else None
+    req = request.Request(url, data=data, method=method)
+    req.add_header("Content-Type", "application/json")
+    req.add_header("Accept", "application/json")
+    req.add_header("Authorization", f"Bearer {OPENWEBUI_ADMIN_TOKEN}")
+    try:
+        with request.urlopen(req, timeout=30) as res:
+            return res.status, json.loads(res.read().decode("utf-8") or "{}")
+    except error.HTTPError as exc:
+        body = exc.read().decode("utf-8")
+        raise RuntimeError(f"HTTP {exc.code} {url}: {body}") from exc
+
+
+def main():
+    if not OPENWEBUI_ADMIN_TOKEN:
+        raise SystemExit("OPENWEBUI_ADMIN_TOKEN is required")
+    results = []
+    for function in FUNCTIONS:
+        content = function["path"].read_text(encoding="utf-8")
+        payload = {
+            "id": function["id"],
+            "name": function["name"],
+            "content": content,
+            "meta": {"description": function["description"]},
+        }
+        try:
+            status, response = http_json("POST", f"{OPENWEBUI_BASE_URL}/api/v1/functions/create", payload)
+        except RuntimeError as exc:
+            if "ID_TAKEN" not in str(exc) and "id_taken" not in str(exc) and "already" not in str(exc).lower():
+                raise
+            status, response = http_json(
+                "POST", f"{OPENWEBUI_BASE_URL}/api/v1/functions/id/{function['id']}/update", payload
+            )
+
+        if not response.get("is_active"):
+            _, response = http_json("POST", f"{OPENWEBUI_BASE_URL}/api/v1/functions/id/{function['id']}/toggle")
+        if function["global"] and not response.get("is_global"):
+            _, response = http_json("POST", f"{OPENWEBUI_BASE_URL}/api/v1/functions/id/{function['id']}/toggle/global")
+
+        results.append({"id": function["id"], "status": status, "is_active": response.get("is_active"), "is_global": response.get("is_global")})
+
+    print(json.dumps({"results": results}, ensure_ascii=False, indent=2))
+
+
+if __name__ == "__main__":
+    main()
