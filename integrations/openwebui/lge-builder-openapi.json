          },
          "externalProjectId": {
            "type": "string"
          },
          "externalRequirementId": {
            "type": "string"
          },
          "externalConceptId": {
            "type": "string"
          },
          "conceptGroupId": {
            "type": "string"
          },
          "conceptThreadId": {
            "type": "string"
          },
          "builderJobId": {
            "type": "string"
          },
          "draftBuildId": {
            "type": "string"
          },
          "snapshotTracePath": {
            "type": "string",
            "const": "artifact.snapshotData.authoringStageTrace"
          }
        }
      }
    }
  }
