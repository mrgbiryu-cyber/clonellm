  "crossFieldRules": [
    {
      "schema": "feedback-projection-v1",
      "rule": "sourceType=critic -> targetCollection=lge-design-history"
    },
    {
      "schema": "feedback-projection-v1",
      "rule": "sourceType=human -> targetCollection=lge-design-history"
    },
    {
      "schema": "feedback-projection-v1",
      "rule": "sourceType=contract-violation -> targetCollection=lge-policy"
    },
    {
      "schema": "feedback-projection-v1",
      "rule": "sourceType=contract-violation -> violationDetail required"
    },
    {
      "schema": "builder-contract-projection-v1",
      "rule": "truthLevel=policy/runtime-truth sources with freshness=stale cannot enter current builder contract"
    },
    {
      "schema": "ontology-projection-v1",
      "rule": "every edge sourceId and targetId must reference existing entities"
    },
    {
      "schema": "ontology-projection-v1",
      "rule": "home.hero must resolve through Page -> has_slot -> Slot -> implemented_by -> Component"
    }
  ]
