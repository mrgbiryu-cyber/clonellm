+          paragraphBuffer = [];
+        };
+        const flushList = () => {
+          if (!listBuffer.length) return;
+          html.push(`<ul>${listBuffer.map((item) => `<li>${escapeHtml(item)}</li>`).join("")}</ul>`);
+          listBuffer = [];
+        };
+        safeLines.forEach((rawLine) => {
+          const line = String(rawLine || "").trim();
+          if (!line) {
+            flushParagraph();
+            flushList();
+            return;
+          }
+          const h3 = line.match(/^###\s+(.+)$/);
+          if (h3) {
+            flushParagraph();
+            flushList();
+            html.push(`<h5 style="margin:0 0 8px;font-size:13px;font-weight:800;color:#344054;">${escapeHtml(h3[1].trim())}</h5>`);
+            return;
