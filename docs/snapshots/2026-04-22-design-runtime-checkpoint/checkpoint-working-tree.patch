+              title: h2[1].trim() || `섹션 ${sections.length + 1}`,
+              lines: [],
+            };
+            sections.push(current);
+            return;
+          }
+          if (!line.trim() && !current) {
+            return;
+          }
+          if (!current) {
+            current = {
+              id: "section-1",
+              title: "내용",
+              lines: [],
+            };
+            sections.push(current);
+          }
+          current.lines.push(line);
+        });
+        return { title, sections };
