+      function parseMarkdownDocument(markdown = "", { defaultTitle = "컨셉서" } = {}) {
+        const lines = String(markdown || "").replace(/\r\n/g, "\n").split("\n");
+        let title = defaultTitle;
+        const sections = [];
+        let current = null;
+        lines.forEach((rawLine) => {
+          const line = String(rawLine || "");
+          const h1 = line.match(/^#\s+(.+)$/);
